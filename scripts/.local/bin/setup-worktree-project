#!/usr/bin/env zsh

# =============================================================================
# setup-worktree-project
#
# Sets up a Laravel worktree with dependencies, env config, and caches.
# Supports both DDEV (Docker) and Herd (native) environments.
#
# Called automatically by claude-worktree after creating a new worktree,
# or can be run standalone in any project directory.
#
# Usage:
#   setup-worktree-project <worktree-path> [main-repo-path]
# =============================================================================

set -e

WORKTREE_PATH="$1"
MAIN_REPO_PATH="$2"

if [[ -z "$WORKTREE_PATH" ]]; then
  echo "Usage: setup-worktree-project <worktree-path> [main-repo-path]"
  exit 1
fi

# Resolve to absolute paths
WORKTREE_PATH=$(cd "$WORKTREE_PATH" && pwd)
if [[ -n "$MAIN_REPO_PATH" ]]; then
  MAIN_REPO_PATH=$(cd "$MAIN_REPO_PATH" && pwd)
fi

cd "$WORKTREE_PATH"

if [[ ! -f "artisan" ]]; then
  echo "⚠ Not a Laravel project. Skipping setup."
  exit 0
fi

# =============================================================================
# Detect environment: DDEV or Herd (native)
# =============================================================================
USE_DDEV=false
if [[ -d ".ddev" ]]; then
  USE_DDEV=true
elif [[ -n "$MAIN_REPO_PATH" && -d "${MAIN_REPO_PATH}/.ddev" ]]; then
  USE_DDEV=true
fi

# =============================================================================
# Helpers
# =============================================================================
symlink_from_main() {
  local file="$1"
  if [[ -n "$MAIN_REPO_PATH" && -f "${MAIN_REPO_PATH}/${file}" && ! -e "${WORKTREE_PATH}/${file}" && ! -L "${WORKTREE_PATH}/${file}" ]]; then
    mkdir -p "$(dirname "${WORKTREE_PATH}/${file}")"
    ln -s "${MAIN_REPO_PATH}/${file}" "${WORKTREE_PATH}/${file}"
    echo "  ✓ Symlinked ${file} → main repo"
  fi
}

copy_from_main() {
  local file="$1"
  if [[ -n "$MAIN_REPO_PATH" && -f "${MAIN_REPO_PATH}/${file}" && ! -f "${WORKTREE_PATH}/${file}" ]]; then
    mkdir -p "$(dirname "${WORKTREE_PATH}/${file}")"
    cp "${MAIN_REPO_PATH}/${file}" "${WORKTREE_PATH}/${file}"
    echo "  ✓ Copied ${file} from main repo"
  fi
}

# Run a command either via ddev or natively depending on environment
run_cmd() {
  if [[ "$USE_DDEV" == true ]]; then
    ddev exec "$@"
  else
    "$@"
  fi
}

# =============================================================================
# DDEV setup (copy config, set unique project name, start containers)
# =============================================================================
if [[ "$USE_DDEV" == true ]]; then
  # Extract the main project's DDEV name for DB container reference.
  # The main repo's db container is accessible at ddev-<name>-db on the
  # shared ddev_default Docker network.
  MAIN_DDEV_NAME=""
  if [[ -n "$MAIN_REPO_PATH" && -f "${MAIN_REPO_PATH}/.ddev/config.yaml" ]]; then
    MAIN_DDEV_NAME=$(grep '^name:' "${MAIN_REPO_PATH}/.ddev/config.yaml" | head -1 | sed 's/^name:[[:space:]]*//')
  fi

  # Copy .ddev/ config from main repo if not already present
  if [[ -n "$MAIN_REPO_PATH" && -d "${MAIN_REPO_PATH}/.ddev" && ! -d "${WORKTREE_PATH}/.ddev" ]]; then
    cp -r "${MAIN_REPO_PATH}/.ddev" "${WORKTREE_PATH}/.ddev"
    echo "  ✓ Copied .ddev config from main repo"
  fi

  # Set a unique DDEV project name based on the worktree directory name.
  # Each DDEV project needs a unique name to avoid port/container conflicts.
  WORKTREE_DIR_NAME=$(basename "$WORKTREE_PATH")
  if [[ -f ".ddev/config.yaml" ]]; then
    sed -i '' "s/^name:.*/name: ${WORKTREE_DIR_NAME}/" .ddev/config.yaml
    echo "  ✓ DDEV project name set to: ${WORKTREE_DIR_NAME}"
  fi

  # Omit the db container — worktrees share the main repo's database.
  # All DDEV projects share the ddev_default network, so the worktree's
  # web container can reach the main db at ddev-<main-name>-db:3306.
  if [[ -f ".ddev/config.yaml" ]]; then
    if ! grep -q '^omit_containers:' .ddev/config.yaml; then
      echo 'omit_containers: [db]' >> .ddev/config.yaml
    else
      sed -i '' 's/^omit_containers:.*/omit_containers: [db]/' .ddev/config.yaml
    fi
    echo "  ✓ DB container omitted (using main repo's database)"
  fi

  # Copy .env BEFORE ddev start — otherwise DDEV generates a default .env
  # and copy_from_main skips because the file already exists.
  copy_from_main ".env"

  # Point DB_HOST at the main repo's database container.
  if [[ -n "$MAIN_DDEV_NAME" && -f ".env" ]]; then
    sed -i '' "s/^DB_HOST=.*/DB_HOST=ddev-${MAIN_DDEV_NAME}-db/" .env
    echo "  ✓ DB_HOST set to ddev-${MAIN_DDEV_NAME}-db"
  fi

  # Start DDEV containers (web only, no db)
  echo "🐳 Starting DDEV..."
  ddev start
fi

# =============================================================================
# Config files from main repo
# =============================================================================
if [[ "$USE_DDEV" != true ]]; then
  # Herd: symlink is fine since all projects share the same DB
  symlink_from_main ".env"
fi

# =============================================================================
# Composer dependencies
# =============================================================================
echo "📦 Running composer install..."
if [[ "$USE_DDEV" == true ]]; then
  # Don't copy composer.lock for DDEV — the main repo's lock file was likely
  # generated under a different PHP version (e.g. Herd's PHP 8.1/8.2) and
  # won't be compatible with the DDEV container's PHP.
  # Use --no-security-blocking so advisories don't prevent installation.
  ddev composer install --no-security-blocking --no-interaction --quiet 2>/dev/null \
    || ddev composer install --no-security-blocking --no-interaction
else
  # Herd: copy composer.lock so `composer install` uses locked versions
  copy_from_main "composer.lock"
  composer install --no-interaction --quiet 2>/dev/null || composer install --no-interaction
fi

# =============================================================================
# Laravel setup
# =============================================================================

# Generate app key if .env exists but APP_KEY is empty
if [[ -f ".env" ]] && grep -q "^APP_KEY=$" .env; then
  echo "🔑 Generating Laravel app key..."
  run_cmd php artisan key:generate --quiet
fi

# Run migrations if we have a database configured.
# Skip for DDEV worktrees — they share the main repo's DB which is already migrated.
if [[ -f ".env" && "$USE_DDEV" != true ]]; then
  echo "🗃️  Running Laravel migrations..."
  run_cmd php artisan migrate --quiet --no-interaction 2>/dev/null || echo "  ⚠ Migrations skipped (DB not available)"
fi

# Clear and rebuild caches for a clean state
echo "🧹 Clearing Laravel caches..."
run_cmd php artisan optimize:clear --quiet 2>/dev/null

# =============================================================================
# Node dependencies (for frontend assets if present)
# =============================================================================
if [[ -f "package.json" ]]; then
  if [[ -f "bun.lockb" || -f "bun.lock" ]]; then
    PM="bun"
  elif [[ -f "pnpm-lock.yaml" ]]; then
    PM="pnpm"
  elif [[ -f "yarn.lock" ]]; then
    PM="yarn"
  else
    PM="npm"
  fi

  echo "📦 Running ${PM} install..."
  if [[ "$USE_DDEV" == true ]]; then
    ddev exec $PM install --silent 2>/dev/null || ddev exec $PM install
  else
    $PM install --silent 2>/dev/null || $PM install
  fi
fi

echo ""
echo "✓ Laravel worktree setup complete"
if [[ "$USE_DDEV" == true ]]; then
  echo "  URL: https://${WORKTREE_DIR_NAME}.ddev.site"
fi
