#!/bin/bash
# ab-search PASS_PATH QUERY
# Outputs matching entries as: email<TAB>name (aerc's expected format)

pass_path="$1"
query="$2"

[ -z "$pass_path" ] && { echo "usage: ab-search PASS_PATH QUERY" >&2; exit 1; }
[ -z "$query" ] && exit 0

# Search whole line case-insensitively, then for each match extract the
# value side (after " : " if present), then split "Name <email>" into TSV.
pass show "$pass_path" 2>/dev/null | grep -i -- "$query" | while IFS= read -r line; do
    # Strip "alias : " prefix if present
    value="${line#*: }"
    [ "$value" = "$line" ] && value="$line"   # no " : ", whole line is the value

    # Parse "Display Name <email@x.com>" or bare "<email@x.com>" or "email@x.com"
    if [[ "$value" =~ ^(.*)[[:space:]]*\<([^\>]+)\>[[:space:]]*$ ]]; then
        name="${BASH_REMATCH[1]}"
        email="${BASH_REMATCH[2]}"
        # Trim trailing whitespace and surrounding quotes from name
        name="${name%"${name##*[![:space:]]}"}"
        name="${name#\"}"; name="${name%\"}"
        printf '%s\t%s\n' "$email" "$name"
    else
        # Bare email address
        printf '%s\t\n' "$value"
    fi
done
