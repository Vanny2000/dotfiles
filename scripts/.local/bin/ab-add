#!/bin/bash
# ab-add PASS_PATH [--all|--from|--to|--cc|--bcc]
# Reads an email message from stdin, extracts addresses from the chosen
# headers, and appends new ones to the pass store entry at PASS_PATH.

pass_path="$1"
mode="${2:---all}"

[ -z "$pass_path" ] && { echo "usage: ab-add PASS_PATH [--all|--from|--to|--cc|--bcc]" >&2; exit 1; }

case "$mode" in
    --all)  headers="From|To|Cc|CC|Bcc" ;;
    --from) headers="From" ;;
    --to)   headers="To" ;;
    --cc)   headers="Cc|CC" ;;
    --bcc)  headers="Bcc" ;;
    *) echo "unknown mode: $mode" >&2; exit 1 ;;
esac

# Load existing entry (empty string if it doesn't exist yet)
existing=$(pass show "$pass_path" 2>/dev/null || true)

# Extract candidate addresses from the message on stdin
candidates=$(perl -CS -MEncode -e '
    use strict; use warnings;
    my $headers_re = shift;
    local $/;
    my $msg = <STDIN>;

    # Cut off body: everything up to first blank line
    $msg =~ s/\r?\n\r?\n.*//s;

    # Unfold headers: a line starting with whitespace continues the previous line
    $msg =~ s/\r?\n[ \t]+/ /g;

    for my $line (split /\r?\n/, $msg) {
        next unless $line =~ /^($headers_re):\s*(.*)$/i;
        my $value = $2;
        # Decode MIME encoded-words
        $value = decode("MIME-Header", $value);
        # Split on commas that are NOT inside double quotes
        my @parts;
        my $depth_q = 0; my $buf = "";
        for my $c (split //, $value) {
            if ($c eq q{"}) { $depth_q = !$depth_q; $buf .= $c; }
            elsif ($c eq "," && !$depth_q) { push @parts, $buf; $buf = ""; }
            else { $buf .= $c; }
        }
        push @parts, $buf if length $buf;
        for my $p (@parts) {
            $p =~ s/^\s+|\s+$//g;
            next unless length $p;
            print $p, "\n";
        }
    }
' "$headers")

# Walk candidates, dedupe against existing + pending, accumulate new lines
to_append=""
while IFS= read -r entry; do
    [ -z "$entry" ] && continue
    case "$entry" in
        *@*) ;;
        *) continue ;;
    esac
    echo "$entry" | grep -iqE 'no[_-]?reply' && continue
    # Squeeze multiple spaces
    entry=$(echo "$entry" | tr -s ' ')
    # Wrap bare email in angle brackets
    case "$entry" in
        *\<*\>*) ;;
        *) entry="<$entry>" ;;
    esac
    # Dedupe against existing entry content and anything queued this run
    combined=$(printf '%s\n%s' "$existing" "$to_append")
    if printf '%s' "$combined" | grep -Fxq "$entry" \
       || printf '%s' "$combined" | grep -Fq ": $entry"; then
        echo "! $entry (skipped)" >&2
        continue
    fi
    echo "+ $entry" >&2
    if [ -z "$to_append" ]; then
        to_append="$entry"
    else
        to_append=$(printf '%s\n%s' "$to_append" "$entry")
    fi
done <<< "$candidates"

[ -z "$to_append" ] && exit 0

# Write merged content back to the pass store (force overwrite, multiline)
{
    [ -n "$existing" ] && printf '%s\n' "$existing"
    printf '%s\n' "$to_append"
} | pass insert -m -f "$pass_path" >/dev/null
